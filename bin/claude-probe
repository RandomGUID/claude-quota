#!/usr/bin/env python3
"""Query claude.ai usage limits via Chrome AppleScript.

Runs a fetch() inside a live Chrome claude.ai tab — no curl, no Cloudflare.

Exit codes:
  0  within limits (or Chrome unavailable — fail open)
  1  one or more limits exceeded

Prints JSON to stdout in all cases.
"""

import subprocess, json, sys

# AppleScript finds any claude.ai tab, fires an async fetch that writes to
# localStorage, waits for it to resolve, then reads the result back.
# Two-step because AppleScript can't await JS Promises directly.
APPLESCRIPT = """
tell application "Google Chrome"
    set claudeTab to missing value
    repeat with w in windows
        repeat with t in tabs of w
            if URL of t contains "claude.ai" then
                set claudeTab to t
                exit repeat
            end if
        end repeat
        if claudeTab is not missing value then exit repeat
    end repeat
    if claudeTab is missing value then
        return "NO_TAB"
    end if
    tell claudeTab
        execute javascript "
            localStorage.removeItem('_claude_probe');
            const org = document.cookie.match(/lastActiveOrg=([^;]+)/)?.[1];
            if (!org) {
                localStorage.setItem('_claude_probe', 'NO_ORG');
            } else {
                fetch('/api/organizations/' + org + '/usage')
                    .then(r => r.ok ? r.json() : Promise.reject('HTTP_' + r.status))
                    .then(d => localStorage.setItem('_claude_probe', JSON.stringify(d)))
                    .catch(e => localStorage.setItem('_claude_probe', 'ERR:' + e));
            }
        "
    end tell
    delay 3
    tell claudeTab
        return execute javascript "localStorage.getItem('_claude_probe') || 'TIMEOUT'"
    end tell
end tell
"""

def main():
    result = subprocess.run(
        ['osascript', '-e', APPLESCRIPT],
        capture_output=True, text=True, timeout=10
    )
    raw = result.stdout.strip()

    if raw in ('NO_TAB', 'NO_ORG', 'missing value', '') or raw.startswith('HTTP_'):
        # Chrome not available or no claude.ai tab — fail open, don't block work
        print(json.dumps({"limited": False, "reason": raw or "no output"}))
        sys.exit(0)

    try:
        data = json.loads(raw)
    except json.JSONDecodeError:
        print(json.dumps({"limited": False, "reason": f"parse error: {raw[:80]}"}))
        sys.exit(0)

    five  = data.get('five_hour') or {}
    seven = data.get('seven_day') or {}

    over_five  = (five.get('utilization')  or 0) >= 100
    over_seven = (seven.get('utilization') or 0) >= 100
    limited    = over_five or over_seven

    out = {
        "limited":   limited,
        "five_hour":  {"utilization": five.get('utilization'),  "resets_at": five.get('resets_at'),  "exceeded": over_five},
        "seven_day":  {"utilization": seven.get('utilization'), "resets_at": seven.get('resets_at'), "exceeded": over_seven},
    }

    if limited:
        candidates = []
        if over_five  and five.get('resets_at'):  candidates.append(five['resets_at'])
        if over_seven and seven.get('resets_at'): candidates.append(seven['resets_at'])
        out['resume_at'] = min(candidates)  # soonest reset wins

    print(json.dumps(out))
    sys.exit(1 if limited else 0)

if __name__ == '__main__':
    main()
